# ============================================================
# Penalty League Mobin (PLM) — Environment Configuration
# ============================================================

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Telegram Channel ID where match updates are posted
# Format: @channelname  OR  -100xxxxxxxxxx
CHANNEL_ID=@your_channel_here

# Comma-separated list of Admin Telegram User IDs
# Example: 123456789,987654321
ADMIN_IDS=123456789,987654321

# SQLite database file path
DATABASE_PATH=plm_database.db

# Match timeout in seconds (how long players have to respond)
MATCH_TIMEOUT=60

# Default number of rounds per match
DEFAULT_ROUNDS=5

# Bot mode: polling or webhook
BOT_MODE=polling

# Webhook settings (only needed if BOT_MODE=webhook)
WEBHOOK_HOST=https://your-app.onrender.com
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=10000
